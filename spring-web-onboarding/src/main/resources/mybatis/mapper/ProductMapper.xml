<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.webflow.product.dao.ProductDao">

    <sql id="productColumns">
        product_id, name, category, price, stock, image_path, created_at
    </sql>

    <select id="findById" resultType="Product">
        SELECT <include refid="productColumns"/>
        FROM product
        WHERE product_id = #{productId}
    </select>

    <!-- 검색 WHERE — search와 countBySearch가 "반드시 같은 조건"을 쓰도록 조각으로 공유 -->
    <sql id="searchWhere">
        <where>
            <if test="condition.keyword != null and condition.keyword != ''">
                AND name LIKE CONCAT('%', #{condition.keyword}, '%')
            </if>
            <if test="condition.category != null and condition.category != ''">
                AND category = #{condition.category}
            </if>
        </where>
    </sql>

    <!--
        🔒 정렬 화이트리스트: 사용자 입력(sort 키)을 ORDER BY에 "직접" 넣지 않는다!
        ${}로 꽂으면 SQL 인젝션 — <choose>로 고정된 SQL 조각 중에서 "선택"만 한다.
        모든 정렬에 PK(product_id)를 포함 — 동률 정렬은 페이징을 흔든다 (TestCraft Step 3 교훈).
    -->
    <select id="search" resultType="Product">
        SELECT <include refid="productColumns"/>
        FROM product
        <include refid="searchWhere"/>
        <choose>
            <when test="condition.sort == 'priceAsc'">ORDER BY price ASC, product_id ASC</when>
            <when test="condition.sort == 'priceDesc'">ORDER BY price DESC, product_id ASC</when>
            <when test="condition.sort == 'name'">ORDER BY name ASC, product_id ASC</when>
            <otherwise>ORDER BY product_id DESC</otherwise> <!-- recent: 최신 등록순 -->
        </choose>
        OFFSET #{offset} ROWS FETCH NEXT #{size} ROWS ONLY
    </select>

    <select id="countBySearch" resultType="long">
        SELECT COUNT(*)
        FROM product
        <include refid="searchWhere"/>
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="productId">
        INSERT INTO product (name, category, price, stock)
        VALUES (#{name}, #{category}, #{price}, #{stock})
    </insert>

    <!--
        재고 차감의 동시성 안전 패턴: 확인(stock >= 수량)과 차감을 한 UPDATE에.
        affected = 0 이면 차감 실패 — SELECT 후 UPDATE 두 문장으로 나누면
        그 사이에 다른 요청이 끼어들어 재고가 음수가 될 수 있다!
    -->
    <update id="updateImagePath">
        UPDATE product
        SET image_path = #{imagePath}
        WHERE product_id = #{productId}
    </update>

    <update id="decreaseStock">
        UPDATE product
        SET stock = stock - #{quantity}
        WHERE product_id = #{productId}
          AND stock >= #{quantity}
    </update>

</mapper>
